# Copy to ".env.local" and fill in values (Next.js reads .env.local automatically; gitignored).
# On Vercel, set the same keys in Project → Settings → Environment Variables.

# Storefront API (GraphQL host is usually your *.myshopify.com domain)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Prefer server-only token (used by /api/storefront + SSR). Falls back to NEXT_PUBLIC_* if unset.
SHOPIFY_STOREFRONT_TOKEN=
# Public fallback (bundled for client if SHOPIFY_STOREFRONT_TOKEN is empty — optional when using API proxy only)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Optional (default: 2025-07)
# NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-07

NEXT_PUBLIC_SITE_URL=https://kryvo.store
NEXT_PUBLIC_SHOPIFY_CHECKOUT_ORIGIN=https://shop.kryvo.store

# ─── SEO / social (optional) ───────────────────────────────────────────────
# Default Open Graph image (full URL, or site-relative path e.g. /og.png)
# NEXT_PUBLIC_OG_IMAGE_URL=https://kryvo.store/og-default.jpg
# Twitter handle without URL
# NEXT_PUBLIC_TWITTER_HANDLE=kryvostore
# Comma-separated profile URLs for Organization JSON-LD (sameAs)
# NEXT_PUBLIC_ORGANIZATION_SAME_AS=https://www.instagram.com/yourprofile
# Google Search Console HTML tag value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-string
